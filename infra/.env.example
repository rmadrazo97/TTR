# TTR POC — local dev config. Copy to `.env`. SYNTHETIC DATA ONLY — never real carrier PII.

# --- Config loading ---
# TTR_ENV_FILE=                     # optional: explicit path to a .env file; config.ts checks this
                                    # first before falling back to infra/.env and ./.env

# --- Postgres (managed EU Postgres in prod) ---
POSTGRES_USER=ttr
POSTGRES_PASSWORD=ttr_dev_pw
POSTGRES_DB=ttr
POSTGRES_PORT=5432
DATABASE_URL=postgres://ttr:ttr_dev_pw@localhost:5432/ttr

# --- Object store: MinIO locally, Cloudflare R2 (jurisdiction=eu) in prod ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=ttr_minio
S3_SECRET_KEY=ttr_minio_dev_pw
S3_REGION=eu
R2_BUCKET=ttr-receipts-eu
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Ingest app ---
INGEST_DOMAIN=ingest.ttr.example    # domain used to build per-driver forwarding addresses
                                    # (seed.ts generates localpart@INGEST_DOMAIN; ingest app
                                    # resolves inbound mail against the same stored value —
                                    # both must agree or findByForwardingAddress silently misses)
INGEST_PORT=8787                    # port the ingest Hono server listens on

# --- Console app ---
PORT=3000                           # port the console Hono server listens on
CONSOLE_USER=asesor                 # Basic-Auth username (POC single shared credential)
CONSOLE_PASSWORD=ttr_dev_pw         # Basic-Auth password

# --- Extraction worker ---
WORKER_IDLE_MS=2000                 # ms to sleep when the document queue is empty

# --- Email ---
# Prod inbound (recommended): Mailgun-EU / Postmark parse webhook -> your worker endpoint.
#   Faster to build (attachments pre-parsed + sender-auth verdicts in one JSON) and Mailgun's
#   EU region clears the GDPR-at-receive question. Cloudflare Email Routing is the all-in-one alt.
# Local: POST a sample webhook JSON to the worker; view outbound acks in Mailpit.
MAIL_PROVIDER=mailgun_eu            # mailgun_eu | postmark | cloudflare
INBOUND_WEBHOOK_SECRET=changeme     # verify the provider's signature on the inbound webhook
SMTP_HOST=localhost                 # Mailpit
SMTP_PORT=1025
ACK_FROM=TTR <recibos@ingest.ttr.example>  # From address for outbound receipt acknowledgements
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# --- LLM vision extraction (provider-agnostic; EU DPA in prod) ---
LLM_API_KEY=                        # real key, or leave blank and use the mock
EXTRACTION_MOCK=true                # true = deterministic stub, no external calls (offline dev)

# --- Optional UIs (compose profiles) ---
ADMINER_PORT=8080                   # --profile tools
APPSMITH_PORT=8090                  # --profile console
